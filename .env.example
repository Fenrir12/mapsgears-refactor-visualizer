PHAB_URL=https://phabricator.example.com/api/
PHAB_API_TOKEN=cli-xxxxxxxxxxxxxxxxxxxx
REPO_CALLSIGN=MYREPO
TARGET_FOLDER=path/to/tracked/folder
COMPARE_FOLDER=path/to/comparison/folder
EXTRA_FOLDERS=path/to/extra/folder1,path/to/extra/folder2
SYNC_INTERVAL_HOURS=6
PORT=3001
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/refactor-visualizer?retryWrites=true&w=majority

# Git clone settings
# GIT_CLONE_URL — explicit git clone URL (optional; derived from PHAB_URL + REPO_CALLSIGN if omitted)
# Example: https://phabricator.example.com/diffusion/MYREPO/repo.git
GIT_CLONE_URL=
# REPO_DIR — local directory for the cloned repo (optional; defaults to /tmp/repo-cache/<CALLSIGN>)
REPO_DIR=

# Authentication (optional — leave blank to disable)
DASHBOARD_PASSWORD=
SESSION_SECRET=some-random-secret-string
